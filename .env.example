# Environment Variables Template
# Copy this file to .env and configure for your environment

# Server Configuration
PORT=3000
NODE_ENV=development

# Organization Configuration
DEFAULT_ORGANIZATION=your-org-name
DEFAULT_ORG_PREFIX=md:cid:org

# Content ID Configuration
# When users only provide title, system auto-generates:
# ${DEFAULT_ORG_PREFIX}:${DEFAULT_ORGANIZATION}:${title-slug}
# Example: "The Matrix" -> "md:cid:org:your-org-name:the-matrix"
